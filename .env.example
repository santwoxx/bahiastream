# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# ENVIRONMENT CONFIG
PORT=3000
NODE_ENV="development"

# CLIENT-SIDE FIREBASE (Prefixed with VITE_ for Vite bundling)
# These can be populated from firebase-applet-config.json
VITE_FIREBASE_API_KEY="AIzaSyCdYmgr1geyEjxYMrXG1o4hYCGUjrwZ5z4"
VITE_FIREBASE_AUTH_DOMAIN="peak-ground-3mln4.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="peak-ground-3mln4"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-e3ea8e54-18c5-4dbb-abd8-7e0a89a710cb"
VITE_FIREBASE_STORAGE_BUCKET="peak-ground-3mln4.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="447762325485"
VITE_FIREBASE_APP_ID="1:447762325485:web:6c04450d84562cc1ac91e4"

